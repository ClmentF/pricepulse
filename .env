# ── Kafka ────────────────────────────────────────────────────────────────────
# Depuis le host (scrapers lancés en local)
KAFKA_BOOTSTRAP=localhost:9092
# Depuis les containers Docker
# KAFKA_BOOTSTRAP=kafka:29092

KAFKA_TOPIC_RAW=raw-prices
KAFKA_TOPIC_VALIDATED=validated-prices
KAFKA_TOPIC_DEAD=dead-letter

# ── NiFi ─────────────────────────────────────────────────────────────────────
NIFI_ENDPOINT=http://localhost:8082/contentListener

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://pp_user:pp_pass@localhost:5432/pricepulse

# ── BigQuery ──────────────────────────────────────────────────────────────────
BIGQUERY_PROJECT=pricepulse-gcp
BIGQUERY_DATASET=pricepulse
BIGQUERY_TABLE=price_history

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API ───────────────────────────────────────────────────────────────────────
API_SECRET_KEY=dev-secret-change-in-prod
CORS_ORIGINS=http://localhost:3000
